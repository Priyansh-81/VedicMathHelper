<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_screen_bg">

    <View
        android:id="@+id/sunRays"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/sun_rays_overlay"
        android:alpha="0.2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/sutraTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sutra Name"
            android:textSize="28sp"
            android:fontFamily="@font/samarkan"
            android:textColor="@color/text_primary"
            android:layout_marginTop="32dp"
            android:gravity="center" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F2FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/questionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="98 × 97"
                    android:textSize="48sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/solutionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <EditText
            android:id="@+id/answerInput"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:hint="Enter your answer"
            android:inputType="number"
            android:layout_marginTop="32dp"
            android:padding="16dp"
            android:gravity="center"
            android:background="@drawable/btn_accent"
            android:textColor="@android:color/white"
            android:textColorHint="#CCFFFFFF"
            android:fontFamily="@font/poppins_medium"
            android:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkBtn"
            style="@style/AccentButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Check Answer"
            android:layout_marginTop="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/backBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to Scanner"
            android:background="?attr/selectableItemBackground"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_medium" />

    </LinearLayout>
</FrameLayout>