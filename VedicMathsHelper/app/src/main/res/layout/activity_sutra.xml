<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_screen_bg">

    <View
        android:id="@+id/sunRays"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/sun_rays_overlay"
        android:alpha="0.2" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:isScrollContainer="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/sutraTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sutra Name"
                android:textSize="28sp"
                android:fontFamily="@font/samarkan"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:gravity="center" />

            <!-- Progress Bar to unlock next Sutra -->
            <LinearLayout
                android:id="@+id/progressContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/progressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress to unlock next: 0%"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_gravity="center" />

                <ProgressBar
                    android:id="@+id/sutraProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressDrawable="@drawable/pill_saffron"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>

            <!-- Feedback Baba -->
            <ImageView
                android:id="@+id/feedbackBaba"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="8dp"
                android:src="@drawable/teaching_baba"
                android:contentDescription="Vedic Baba"
                android:scaleType="centerInside" />

            <!-- Problem Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F2FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/problemHeaderText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="98 × 97"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/poppins_semibold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/stepCounterText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Step 1 of 3"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="4dp" />

                    <View
                        android:layout_width="60dp"
                        android:layout_height="2dp"
                        android:background="@color/soft_saffron"
                        android:layout_marginVertical="12dp" />

                    <TextView
                        android:id="@+id/questionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Step Instruction"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/hintText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hint goes here"
                        android:textSize="15sp"
                        android:textColor="@color/saffron"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginTop="6dp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/solutionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="17sp"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <EditText
                android:id="@+id/answerInput"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="Enter step answer"
                android:inputType="number"
                android:layout_marginTop="24dp"
                android:padding="16dp"
                android:gravity="center"
                android:background="@drawable/btn_accent"
                android:textColor="@android:color/white"
                android:textColorHint="#CCFFFFFF"
                android:fontFamily="@font/poppins_medium"
                android:elevation="4dp"
                android:imeOptions="actionDone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/checkBtn"
                    style="@style/AccentButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Check Step" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/nextBtn"
                    style="@style/OutlineButton_saffron"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:text="New Question" />

            </LinearLayout>

            <!-- Extra padding to ensure buttons can scroll above keyboard -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>